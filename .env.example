# Database Configuration
# DB_TYPE: sqlite (default) or postgres
DB_TYPE=sqlite

# SQLite configuration (used when DB_TYPE=sqlite)
DB_PATH=data.db

# PostgreSQL configuration (used when DB_TYPE=postgres)
DATABASE_URL=postgresql://tradingview:password@localhost:5432/tradingview
POSTGRES_PASSWORD=tradingview_dev_password

# SerpApi news cache (comma-separated keys; kept in env/secret, not DB)
SERPAPI_API_KEYS=
SERPAPI_NEWS_CACHE_TTL_SEC=10800
SERPAPI_MIN_INTERVAL_SEC=10800
SERPAPI_MONTHLY_QUOTA_PER_KEY=250
SERPAPI_USAGE_STATE_PATH=/app/data/serpapi_usage.json
SERPAPI_TIMEOUT_SEC=6
