# Database Configuration
# PostgreSQL is the runtime default and production source of truth.
DB_TYPE=postgres

# Docker Compose connection. Host-side execution should use localhost instead.
DATABASE_URL=postgresql://tradingview:tradingview_dev_password@postgres:5432/tradingview
POSTGRES_PASSWORD=tradingview_dev_password

# SerpApi news cache (comma-separated keys; kept in env/secret, not DB)
SERPAPI_API_KEYS=
SERPAPI_NEWS_CACHE_TTL_SEC=10800
SERPAPI_MIN_INTERVAL_SEC=10800
SERPAPI_MONTHLY_QUOTA_PER_KEY=250
SERPAPI_USAGE_STATE_PATH=/app/data/serpapi_usage.json
SERPAPI_TIMEOUT_SEC=6
